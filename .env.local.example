# Copy to .env.local and fill in. NEVER commit .env.local.

# --- Local NIM / OpenAI-compatible inference (Section 4) ---
# Local NVIDIA NIM default. Also works against Ollama (http://localhost:11434/v1)
# or any OpenAI-compatible server.
NIM_BASE_URL=http://localhost:8000/v1
NIM_MODEL=meta/llama-3.1-8b-instruct
# NIM_API_KEY=            # usually empty for local NIM

# --- Optional cloud fallback mirror (used only if local is unreachable) ---
# CLOUD_LLM_BASE_URL=https://api.openai.com/v1
# CLOUD_LLM_API_KEY=sk-...
# CLOUD_LLM_MODEL=gpt-4o-mini

# --- Pulling NIM images (host-side, not read by the app) ---
# Required by `docker compose` to pull from NVIDIA NGC. Get a key at ngc.nvidia.com.
# NGC_API_KEY=

# --- Cross-device enrollment (Section 2) ---
# Leave UNSET to keep device enrollment fully disabled. Set to a long random
# secret only when you deliberately want to allow opt-in device registration.
# DEVICE_ENROLL_TOKEN=

# Wholesaling integrations (set via /env page)
# BLAND_API_KEY=            # Bland.ai AI calling
# GOOGLE_VOICE_NUMBER=      # your Google Voice number for click-to-call
# PROPSTREAM_URL=https://login.propstream.com

# Regrid parcel data API (real nationwide parcel records)
# REGRID_API_TOKEN=

# Email agent (your own mailbox)
# SMTP_HOST=  SMTP_PORT=587  SMTP_USER=  SMTP_PASS=  SMTP_SECURE=false
# IMAP_HOST=  IMAP_PORT=993  IMAP_USER=  IMAP_PASS=   (to read inbox)

# MLS via RESO Web API (your licensed brokerage/MLS credentials)
# MLS_RESO_URL=    e.g. https://api.mlsgrid.com/v2
# MLS_RESO_TOKEN=

# Email agent (your own mailbox)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# IMAP_HOST=
# IMAP_PORT=993
# IMAP_USER=
# IMAP_PASS=

# MLS via RESO Web API (your licensed brokerage/MLS feed)
# MLS_RESO_URL=
# MLS_RESO_TOKEN=

# DocuSign eSignature (your account)
# DOCUSIGN_BASE_URI=https://demo.docusign.net/restapi
# DOCUSIGN_ACCOUNT_ID=
# DOCUSIGN_TOKEN=

# WhatsApp Business Cloud API (Meta)
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_ID=

# Native email (use your own mailbox; Gmail needs an App Password)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your_app_password
# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993
# IMAP_USER=you@gmail.com   # defaults to SMTP_USER if unset
# IMAP_PASS=your_app_password

# ATTOM Data API — PropStream-style property data (detail, AVM, tax, comps)
# ATTOM_API_KEY=
